# Copy this file to .env and fill in the values.
# docker compose up -d starts Postgres — DATABASE_URL below points at it.

# ── Required ──────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://creatrix:password@localhost:5432/creatrix

# Change this to a long random string before running.
SESSION_SECRET=change-me-to-a-long-random-string

# ── Optional — AI providers ───────────────────────────────────────────────────
# AI connections are configured through the UI and stored in the database.
# You do NOT need to set these here. They are listed only so you know they exist.

# OPENAI_API_KEY=sk-...

# Ollama is auto-discovered at localhost:11434 — no config needed.
# LM Studio is auto-discovered at localhost:1234 — no config needed.

# Notion integration token — get this from https://www.notion.so/my-integrations
# Create an internal integration, copy the token, then share each page/database
# you want Creatrix to access with that integration inside Notion.
# NOTION_TOKEN=secret_...
